---
import type { Post } from '~/types';
import { APP_BLOG } from 'astrowind:config';
import { getPermalink } from '~/utils/permalinks';

interface Props {
  tags: Post['tags'];
  class?: string;
  title?: string;
  isCategory?: boolean;
}

const { tags, class: className = 'text-sm', title, isCategory = false } = Astro.props;

const isTagEnabled = APP_BLOG?.tag?.isEnabled;
---

{
  tags && Array.isArray(tags) && (
    <>
      {title && (
        <span class="align-super font-normal underline underline-offset-4 decoration-2 dark:text-slate-400">
          {title}
        </span>
      )}
      <ul class={className}>
        {tags.map((tag) => (
          <li class="inline-block mb-2 mr-2 bg-gray-100 px-2 py-0.5 font-medium lowercase dark:bg-slate-700 rtl:ml-2 rtl:mr-0">
            {isTagEnabled ? (
              <a
                href={getPermalink(tag, isCategory ? 'category' : 'tag')}
                class="text-muted hover:text-primary dark:text-slate-300 dark:hover:text-gray-200"
              >
                {tag}
              </a>
            ) : (
              tag
            )}
          </li>
        ))}
      </ul>
    </>
  )
}
