---
import ContactUs from '~/components/widgets/Contact.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contacte',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contacte" />

  <ContactUs
    title={`Envia'ns un missatge!`}
    button="Enviar"
    subtitle=`Si vols fer-te soci o col·laborar amb nosaltres envia'ns un missatge, i et respondrem tan aviat com puguem.`
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nom',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Missatge',
    }}
    disclaimer={{
      label:
        'En enviar aquest formulari de contacte, reconeixes i acceptes la recollida de la teva informació personal.',
    }}
  />
</Layout>
