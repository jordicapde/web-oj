---
import { getCollection } from 'astro:content';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const allSocis = await getCollection('socis');
const sociDelMes = allSocis.find((soci) => soci.data.partner_of_the_month === true);

const metadata = { title: 'Soci del Mes' };

const formattedDate = sociDelMes?.data.date
  ? new Intl.DateTimeFormat('ca', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(sociDelMes.data.date))
  : '';

let SociContent;
if (sociDelMes) {
  const rendered = await sociDelMes.render();
  SociContent = rendered.Content;
}
---

<Layout metadata={metadata}>
  <HeroText tagline='Reconeixement mensual' title='Soci del Mes' />

  {
    sociDelMes ? (
      <div class='container mx-auto px-4 py-8'>
        <div class='max-w-4xl mx-auto bg-purple-900/10 dark:bg-slate-900 rounded-xl shadow-lg overflow-hidden '>
          <div class='md:flex'>
            <div class='p-8 w-full'>
              {/* Profile Content */}
              <div class='max-w-3xl mx-auto prose prose-lg dark:prose-invert px-4 mb-6 border-b border-gray-200 dark:border-gray-700 pb-6'>
                <SociContent />
              </div>

              <div class='grid md:grid-cols-2 gap-6 px-4'>
                {/* Member Since */}
                <div class='bg-gray-50 dark:bg-slate-800 p-6 rounded-lg'>
                  <h3 class='text-xl font-bold text-primary dark:text-blue-300 mb-2'>Amb nosaltres des de</h3>
                  <p class='text-lg'>{formattedDate}</p>
                  <br />
                  <h3 class='text-xl font-bold text-primary dark:text-blue-300 mb-2'>Càrrec a l'associació</h3>
                  <p class='text-lg'>{sociDelMes.data.role}</p>
                </div>

                {/* Favorite Game */}
                <div class='bg-primary bg-opacity-10 dark:bg-slate-800 p-6 rounded-lg'>
                  <h3 class='text-xl font-bold text-white dark:text-blue-300 mb-2'>Joc Preferit</h3>
                  <div class='flex flex-col sm:flex-row items-center'>
                    <div class='flex-1'>
                      <p class='text-lg mb-3 text-white'>{sociDelMes.data.favorite_game.game}</p>
                      <a
                        href={sociDelMes.data.favorite_game.url}
                        target='_blank'
                        rel='noopener noreferrer'
                        class='inline-block'
                      >
                        <img
                          src={sociDelMes.data.favorite_game.image}
                          alt={sociDelMes.data.favorite_game.game}
                          class='w-24 h-24 rounded-md shadow-md transition-transform hover:scale-105'
                        />
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class='container mx-auto px-4 py-16 text-center'>
        <div class='max-w-lg mx-auto bg-white dark:bg-slate-900 rounded-xl shadow-lg p-8'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-16 w-16 mx-auto text-gray-400 mb-6'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
            />
          </svg>
          <p class='text-2xl font-bold text-gray-800 dark:text-white mb-4'>
            Encara no tenim un soci del mes seleccionat.
          </p>
          <p class='text-lg text-gray-600 dark:text-gray-300'>
            Torna aviat per descobrir qui serà el proper soci destacat!
          </p>
        </div>
      </div>
    )
  }
</Layout>

<!-- Conditional confetti script -->
{sociDelMes && (
  <script>
    var count = 200;
    var defaults = {
      origin: { y: 0.7 },
    };

    function fire(particleRatio, opts) {
      confetti({
        ...defaults,
        ...opts,
        particleCount: Math.floor(count * particleRatio),
      });
    }

    fire(0.25, {
      spread: 26,
      startVelocity: 55,
    });
    fire(0.2, {
      spread: 60,
    });
    fire(0.35, {
      spread: 100,
      decay: 0.91,
      scalar: 0.8,
    });
    fire(0.1, {
      spread: 120,
      startVelocity: 25,
      decay: 0.92,
      scalar: 1.2,
    });
    fire(0.1, {
      spread: 120,
      startVelocity: 45,
    });
  </script>
)}
