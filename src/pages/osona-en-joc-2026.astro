---
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Osona en Joc 2026',
};

const entitats = [
  { nom: 'Ajuntament de Calldetenes', logo: 'https://seu-e.cat/image/layout_set_logo?img_id=17182739&t=1776617876450' },
];

// A confirmar:
// - joc de rol, minis, ordre de tornejos
const franges = ['Tot el dia', 'Matí', 'Tarda'];
const activitats = [
  {
    franja: "Tot el dia",
    titol: "Ludoteca oberta de jocs de taula",
    subtitol: "Jocs de taula per a totes les edats, des d'infantil fins a adults",
    descripcio: "Vine a gaudir d'una selecció de jocs per a tothom. T'ajudarem a trobar el joc perfecte per a tu i si no el coneixes, no et preocupis: nosaltres t'ensenyem a jugar.",
  },
  {
    franja: "Tot el dia",
    titol: "Demostracions de jocs de taula",
    descripcio: "Descobreix i prova les novetats de les editorials. Nosaltres ens encarreguem d'explicar el joc, tu només l'has d'escollir.",
    colaborador: "Devir, 2Tomatoes, Tranjis Games, Enpeudejoc Edicions",
  },
  {
    franja: "Tot el dia",
    titol: "Jocs de fusta, d'exterior i tradicionals",
    descripcio: "Torna a connectar amb els jocs de tota la vida i posa a prova la teva habilitat.",
    colaborador: "Companyia de jocs L'Anònima",
  },
  {
    franja: "Tot el dia",
    titol: "Jocs de taula de gats",
    descripcio: "Vine a jugar a jocs de temàtica felina i coneix la feina que fa l'associació d'Amics dels Gats.",
    colaborador: "Amics dels Gats de Calldetenes",
  },
  {
    franja: "Tot el dia",
    titol: "Tornejos",
    descripcio: "Participa als tornejos de jocs de taula, hi haurà premis per als guanyadors! Tots el jocs seran senzills i es podran aprendre abans de jugar.",
  },
  {
    franja: "Tot el dia",
    titol: "Sorteigs",
    descripcio: "No marxeu abans d'hora, que hi haurà jocs, vals de compra i altres productes per qui participi i es quedi fins al final!",
    colaborador: "Gargamel Joguines, Abacus, Llibreria Contijoch, Bonpreu Esclat, Comerç local de Calldetenes",
  },
  {
    franja: "Matí",
    titol: "Partides de Rummikub",
    horari: "A partir de les 11:00",
    descripcio: "Els clàssics no moren mai. Prepara les neurones per desfer-te de tots els teus números.",
    colaborador: "Casal d'avis de Calldetenes",
  },
  {
    franja: "Matí",
    titol: "La Cuenta",
    subtitol: "Torneig",
    horari: "11:00",
    descripcio: "La Cuenta és el joc on aneu de tapes esperant que no et toqui a tu pagar tota la ronda. Demana un altre plat i creua les dits perquè no et torni.",
    colaborador: "2Tomatoes",
    imatge: "https://cf.geekdo-images.com/LJ-bH8ZCrVUZpwEhzjdE-Q__original/img/vplwH-lS7OGvzalcvQH8EqFbVZk=/0x0/filters:format(png)/pic8660315.png"
  },
  {
    franja: "Matí",
    titol: "Blood on the Clocktower",
    subtitol: "Joc de rols ocults",
    horari: "11:30",
    descripcio: "La millor experiència de rols ocults del moment. Els jugadors es divideixen en dos bàndols: els bons i els dolents. Sabràs trobar qui és qui abans que sigui massa tard?",
    colaborador: "Molins de Jocs",
    imatge: "https://cf.geekdo-images.com/HINb2nkFn5IiZxAlzQIs4g__original/img/e7izEwSmnBPiErsIF6hlWbgybBE=/0x0/filters:format(jpeg)/pic7009391.jpg"
  },
  {
    franja: "Matí",
    titol: "Coupage",
    subtitol: "Joc de taula + tast de vins",
    horari: "12:00",
    descripcio: "Coupage és un joc de cartes ambientat en l'elaboració de vins. I quina millor manera de jugar-lo que acompanyat d'un tast de vins?",
    colaborador: "Garnatxa Blanca Games, Celler Simeó Parareda",
    imatge: "https://www.coupagejoc.com/wp-content/uploads/2025/10/Ed-final-050746-2-scaled.jpg"
  },
  {
    franja: "Matí",
    titol: "Agent Avenue",
    subtitol: "Torneig",
    horari: "13:00",
    descripcio: "Agent Avenue és un carrera psicològica entre dos jugadors intentant atrapar-se. Qui serà més hàbil per enganyar al seu rival?",
    colaborador: "Devir",
    imatge: "https://cf.geekdo-images.com/qC5YwZANir1Cmg6d-1UUpQ__original/img/26YgtJFY_7vKONVD87cHDb1pWRs=/0x0/filters:format(png)/pic8427963.png"
  },
  {
    franja: "Tarda",
    titol: "Partides d'escacs",
    horari: "A partir de les 16:00",
    descripcio: "Posa a prova la teva estratègia i habilitat. Tant si ets un jugador experimentat com si només vols provar-ho, aquest és el moment d'asseure's a la taula.",
    colaborador: "Club d'escacs de Calldetenes",
  },
  {
    franja: "Tarda",
    titol: "Espai infantil i primera infància",
    horari: "16:00 - 18:00",
    descripcio: "Els més petits també tenen el seu espai per jugar i divertir-se amb joc lliure i adaptat.",
    colaborador: "La Rutlla",
  },
  {
    franja: "Tarda",
    titol: "Blood on the Clocktower",
    subtitol: "Joc de rols ocults",
    horari: "17:00",
    descripcio: "La millor experiència de rols ocults del moment. Els jugadors es divideixen en dos bàndols: els bons i els dolents. Sabràs trobar qui és qui abans que sigui massa tard?",
    colaborador: "Molins de Jocs",
    imatge: "https://cf.geekdo-images.com/HINb2nkFn5IiZxAlzQIs4g__original/img/e7izEwSmnBPiErsIF6hlWbgybBE=/0x0/filters:format(jpeg)/pic7009391.jpg"
  },
  {
    franja: "Tarda",
    titol: "Coyote",
    subtitol: "Torneig",
    horari: "17:00",
    descripcio: "Coyote és el joc on intentes endevinar quina és la suma total de números sense saber el que tu tens al front. Dissimula i fes la teva aposta amb seguretat.",
    colaborador: "Devir",
    imatge: "https://cf.geekdo-images.com/SI7PmZvgnG_eGtTLjDUFXw__original/img/yCBhkklKvQiXMW_lZtFBJV6a1tE=/0x0/filters:format(jpeg)/pic6884733.jpg"
  },
];
---

<Layout metadata={metadata}>
  <HeroText 
    tagline="Esdeveniments" 
    title="Fira Osona en Joc 2026" 
  />

  <section class="px-4 py-4 mx-auto max-w-4xl">
    
    <div class="prose prose-lg dark:prose-invert max-w-none mb-12 text-center">
      <p>
        Benvinguts a la segona edició de la <strong>Fira Osona en Joc</strong>, l'esdeveniment que vol apropar el món lúdic i dels jocs de taula a tota la comarca d'Osona. La jornada està pensada per a tothom, des dels més petits fins als més grans (<i>perquè sí, es veu que els adults també juguen!</i>). El joc és cultura, aprenentatge i convivència. Asseieu-vos a la taula per comprovar-ho!
        <br><br>
        <span class="font-bold text-slate-600 dark:text-slate-400">Fet des de Calldetenes, seu de l'associació Osona Juga</span>
      </p>
    </div>

    <hr class="my-16 border-slate-200 dark:border-slate-700" />

    <div class="pb-12">
      <h3 class="text-center text-sm font-bold uppercase tracking-widest text-slate-500 mb-8">
        Amb el suport de
      </h3>
      
      <div class="flex flex-wrap justify-center items-center gap-8 transition-all">
        {entitats.map((entitat) => (
          <div class="flex flex-col items-center">
            {entitat.logo ? (
              <img src={entitat.logo} alt={entitat.nom} class="h-12 w-auto mb-2" />
            ) : (
              <span class="font-bold text-slate-600 dark:text-slate-400">{entitat.nom}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Programa d'activitats -->
  <section class="px-4 py-4 sm:px-6 mx-auto lg:px-8 lg:py-16 max-w-4xl">
    <div class="prose prose-lg max-w-none dark:prose-invert">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-slate-50 dark:bg-slate-800 p-8 rounded-xl border border-slate-200 dark:border-slate-700 mb-12">
        <div>
          <h3 class="text-secondary font-bold mb-2 mt-0">Lloc</h3>
          <p class="m-0">
            <strong>Calldetenes</strong><br />
            Plaça Onze de Setembre
          </p>
        </div>
        <div>
          <h3 class="text-secondary font-bold mb-2 mt-0">Data</h3>
          <p class="m-0">
            <strong>30 de maig de 2026</strong><br />
            De 10h a 14h i de 16h a 20h
          </p>
        </div>
      </div>

      <hr class="my-10 border-slate-200 dark:border-slate-700" />

      <h2 class="text-3xl font-bold text-center mb-6">Programa d'activitats</h2>
      
      <!--
      <div class="text-center p-10 bg-white dark:bg-slate-900 rounded-lg shadow-sm border border-dashed border-slate-400">
        <p class="text-xl italic text-slate-600 dark:text-slate-400">
          Estem acabant de perfilar els últims detalls per oferir-vos la millor experiència lúdica
        </p>
        <p class="font-bold text-secondary text-2xl mt-4">
          Estigueu atents, ben aviat apareixerà!
        </p>
      </div>
      -->
      
      {franges.map((nomFranja) => (
        // Només dibuixem la secció si hi ha activitats en aquesta franja
        activitats.some(a => a.franja === nomFranja) && (
          <div class="mb-16">
            {/* Títol de secció */}
            <div class="flex items-center mb-8">
              <h3 class="text-2xl font-bold uppercase tracking-wider text-primary mt-0 mb-0">{nomFranja}</h3>
              <div class="flex-grow ml-4 border-t-2 border-primary"></div>
            </div>
  
            {/* Activitats de la franja */}
            {activitats
              .filter(a => a.franja === nomFranja)
              .map((activitat) => (
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm mb-6 flex flex-col md:flex-row">
                  
                  {/* IMATGE (Només si existeix) */}
                  {activitat.imatge && (
                    <div class="md:w-1/3 lg:w-1/4 not-prose">
                      <img 
                        src={activitat.imatge} 
                        alt={activitat.titol} 
                        class="h-48 md:h-full w-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}
            
                  {/* CONTINGUT DE TEXT */}
                  <div class={`p-6 md:p-8 flex-grow ${activitat.imatge ? 'md:w-2/3 lg:w-3/4' : 'w-full'}`}>
                    <div class="flex justify-between items-start mb-2">
                      <h4 class="text-2xl font-bold mt-0">{activitat.titol}</h4>
                      {activitat.horari && (
                        <span class="bg-secondary/10 text-secondary text-sm font-bold px-3 py-1 rounded-full whitespace-nowrap ml-4">
                          {activitat.horari}
                        </span>
                      )}
                    </div>
                    
                    {activitat.subtitol && (
                      <p class="text-primary font-medium mb-4 italic">{activitat.subtitol}</p>
                    )}
                    
                    <div class="text-slate-600 dark:text-slate-400">
                      <p>{activitat.descripcio}</p>
                    </div>
            
                    {activitat.colaborador && (
                      <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800 text-sm">
                         <span class="text-slate-500 italic text-xs uppercase tracking-widest">En col·laboració amb:</span> 
                         <br/>
                         <strong class="text-slate-700 dark:text-slate-300">{activitat.colaborador}</strong>
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        )
      ))}
    </div>
  </section>
</Layout>
